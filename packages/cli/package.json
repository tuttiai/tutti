{
  "name": "@tuttiai/cli",
  "version": "0.11.0",
  "description": "Tutti CLI — scaffold and run multi-agent projects",
  "type": "module",
  "bin": {
    "tutti-ai": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tuttiai/core": "*",
    "@tuttiai/server": "*",
    "@tuttiai/types": "*",
    "chalk": "5.6.2",
    "chokidar": "5.0.0",
    "commander": "4.1.1",
    "dotenv": "17.4.1",
    "enquirer": "2.4.1",
    "express": "^5.2.1",
    "ora": "8.2.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "keywords": [
    "tutti",
    "ai",
    "agents",
    "orchestration",
    "cli",
    "scaffold"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tuttiai/tutti",
    "directory": "packages/cli"
  },
  "homepage": "https://tutti-ai.com",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/pino": "^7.0.4"
  }
}
