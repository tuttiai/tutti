{
  "name": "@tuttiai/rag",
  "version": "0.1.0",
  "description": "Tutti voice — retrieval-augmented generation: ingest, search, and manage a knowledge base",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tuttiai/core": "*",
    "@tuttiai/types": "*",
    "pdf-parse": "2.4.5",
    "pg": "8.20.0",
    "pgvector": "0.2.1",
    "remark": "^15.0.1",
    "strip-markdown": "^6.0.0",
    "unified": "^11.0.5",
    "wink-bm25-text-search": "3.1.2",
    "wink-nlp-utils": "2.1.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.15.0"
  },
  "keywords": ["tutti", "ai", "agents", "voice", "rag", "retrieval", "knowledge-base", "embeddings"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tuttiai/tutti",
    "directory": "voices/rag"
  },
  "homepage": "https://tutti-ai.com"
}
