{
  "name": "@tuttiai/email",
  "version": "0.1.0",
  "description": "Tutti voice — read and send email via IMAP IDLE + SMTP; shared client for @tuttiai/inbox",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "imapflow": "1.3.3",
    "mailparser": "3.9.8",
    "nodemailer": "8.0.7",
    "zod": "3.25.76"
  },
  "peerDependencies": {
    "@tuttiai/core": ">=0.11.0",
    "@tuttiai/types": ">=0.9.0"
  },
  "devDependencies": {
    "@types/mailparser": "3.4.6",
    "@types/nodemailer": "7.0.2"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tuttiai/tutti",
    "directory": "voices/email"
  },
  "homepage": "https://tutti-ai.com",
  "keywords": ["tutti", "ai", "agents", "email", "imap", "smtp", "voice"]
}
