{
  "name": "@tuttiai/core",
  "version": "0.18.0",
  "description": "Tutti runtime — multi-agent orchestration for TypeScript",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.39.0",
    "@google/generative-ai": "0.21.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@tuttiai/telemetry": "*",
    "@tuttiai/types": "*",
    "diff": "^9.0.0",
    "ioredis": "5.10.1",
    "openai": "4.104.0",
    "pg": "8.20.0",
    "node-cron": "3.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "3.25.76",
    "zod-to-json-schema": "3.25.2"
  },
  "keywords": [
    "tutti",
    "ai",
    "agents",
    "orchestration",
    "runtime",
    "llm",
    "anthropic",
    "openai",
    "gemini"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tuttiai/tutti",
    "directory": "packages/core"
  },
  "homepage": "https://tutti-ai.com",
  "devDependencies": {
    "@types/pg": "8.20.0",
    "@types/pino": "^7.0.4"
  }
}
