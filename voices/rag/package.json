{
  "name": "@tuttiai/rag",
  "version": "0.1.0",
  "description": "Tutti voice — retrieval-augmented generation: ingest, search, and manage a knowledge base",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
