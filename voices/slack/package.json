{
  "name": "@tuttiai/slack",
  "version": "0.1.1",
  "description": "Tutti voice — read, post and moderate Slack messages from agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@slack/socket-mode": "2.0.4",
    "@slack/web-api": "7.10.0",
    "zod": "3.25.76"
  },
  "peerDependencies": {
    "@tuttiai/core": ">=0.11.0",
    "@tuttiai/types": ">=0.9.0"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tuttiai/tutti",
    "directory": "voices/slack"
  },
  "homepage": "https://tutti-ai.com",
  "keywords": ["tutti", "ai", "agents", "slack", "chatbot", "voice"]
}
