# Required — LLM for every agent
ANTHROPIC_API_KEY=

# Required for the content agent's RAG voice (brand knowledge base)
# See tutti.score.ts for swapping to a local / Voyage AI provider.
OPENAI_API_KEY=

# Required for the twitter agent
# Bearer token is enough for read tools (search, get, mentions, replies, user, timeline).
# OAuth 1.0a quadruple is required for write tools (post, thread, delete).
# Create credentials at https://developer.x.com
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Required for the discord agent
# Create a bot at https://discord.com/developers/applications, copy the
# token here, and invite it to your server with the required intents
# (Server Members, Message Content) enabled in the portal.
DISCORD_BOT_TOKEN=
