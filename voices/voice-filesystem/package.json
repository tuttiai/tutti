{
  "name": "@tuttiai/voice-filesystem",
  "version": "0.1.0",
  "description": "Filesystem voice for Tutti — read, write, and search files",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
