{
  "name": "@tuttiai/core",
  "version": "0.3.0",
  "description": "Tutti runtime — multi-agent orchestration for TypeScript",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.39.0",
    "@google/generative-ai": "0.21.0",
    "@tuttiai/types": "*",
    "openai": "4.104.0",
    "zod": "3.25.76",
    "zod-to-json-schema": "3.25.2"
  },
  "keywords": ["tutti", "ai", "agents", "orchestration", "runtime", "llm", "anthropic", "openai", "gemini"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tuttiai/tutti",
    "directory": "packages/core"
  },
  "homepage": "https://tutti-ai.com"
}
