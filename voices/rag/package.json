    "zod": "3.25.76"
  },
  "keywords": ["tutti", "ai", "agents", "voice", "rag", "retrieval", "knowledge-base", "embeddings"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tuttiai/tutti",
    "directory": "voices/rag"
  },
  "homepage": "https://tutti-ai.com"
}
