    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tuttiai/types": "*",
    "glob": "^11.0.0",
    "zod": "^3.24.0"
  },
  "license": "MIT"
