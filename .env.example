# ── Tutti Server ─────────────────────────────────────────────
# Required: API key clients must send in Authorization: Bearer <key>
TUTTI_API_KEY=change-me

# ── LLM Provider (pick one) ─────────────────────────────────
# Provider: anthropic (default) | openai | gemini | openrouter
TUTTI_PROVIDER=anthropic

# Provide the API key for your chosen provider:
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...
# OPENROUTER_API_KEY=sk-or-...    # 300+ models — see https://openrouter.ai/models

# ── Model ────────────────────────────────────────────────────
TUTTI_MODEL=claude-sonnet-4-20250514

# ── Agent ────────────────────────────────────────────────────
TUTTI_AGENT_NAME=assistant
TUTTI_SYSTEM_PROMPT=You are a helpful assistant.

# ── Server ───────────────────────────────────────────────────
TUTTI_PORT=3847
# TUTTI_HOST=0.0.0.0           # set automatically in docker-compose
# TUTTI_ALLOWED_ORIGINS=*      # comma-separated origins for CORS
# TUTTI_RATE_LIMIT_MAX=60      # requests per window (default: 60)
# TUTTI_RATE_LIMIT_WINDOW=1 minute

# ── Database (docker-compose sets these automatically) ───────
# DATABASE_URL=postgres://tutti:tutti_dev@localhost:5432/tutti
# TUTTI_REDIS_URL=redis://localhost:6379

# ── Docker Compose ───────────────────────────────────────────
POSTGRES_PASSWORD=tutti_dev

# ── Observability ────────────────────────────────────────────
# TUTTI_LOG_LEVEL=info
# NODE_ENV=production
