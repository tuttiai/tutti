{
  "name": "@tuttiai/filesystem",
  "version": "0.1.0",
  "description": "Filesystem voice for Tutti — read, write, and search files",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "glob": "11.1.0",
    "zod": "3.25.76"
  },
  "peerDependencies": {
    "@tuttiai/types": ">=0.7.0"
  },
  "keywords": ["tutti", "ai", "agents", "orchestration", "voice", "filesystem", "files", "io"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tuttiai/tutti",
    "directory": "voices/filesystem"
  },
  "homepage": "https://tutti-ai.com"
}
