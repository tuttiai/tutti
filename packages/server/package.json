{
  "name": "@tuttiai/server",
  "version": "0.2.0",
  "description": "Tutti HTTP server — runs agents over REST via `tutti-ai serve`",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/rate-limit": "10.3.0",
    "fastify": "5.8.4"
  },
  "peerDependencies": {
    "@tuttiai/core": ">=0.11.0",
    "@tuttiai/types": ">=0.7.0"
  },
  "keywords": [
    "tutti",
    "ai",
    "agents",
    "orchestration",
    "server",
    "http",
    "fastify",
    "rest",
    "sse"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tuttiai/tutti",
    "directory": "packages/server"
  },
  "homepage": "https://tutti-ai.com"
}
