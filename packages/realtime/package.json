{
  "name": "@tuttiai/realtime",
  "version": "0.1.0",
  "description": "Realtime API client for Tutti — thin WebSocket wrapper over the OpenAI Realtime protocol",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tuttiai/core": "*",
    "@tuttiai/types": "*",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.0"
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "keywords": [
    "tutti",
    "ai",
    "agents",
    "realtime",
    "openai",
    "websocket",
    "voice",
    "audio"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tuttiai/tutti",
    "directory": "packages/realtime"
  },
  "homepage": "https://tutti-ai.com",
  "engines": {
    "node": ">=22"
  }
}
