{
  "name": "@tuttiai/web",
  "version": "0.1.0",
  "description": "Web voice for Tutti — search, fetch pages, and read sitemaps with Brave, Serper, or DuckDuckGo",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mozilla/readability": "0.6.0",
    "linkedom": "0.18.12",
    "lru-cache": "11.3.5",
    "zod": "3.25.76"
  },
  "peerDependencies": {
    "@tuttiai/core": ">=0.11.0",
    "@tuttiai/types": ">=0.7.0"
  },
  "keywords": [
    "tutti",
    "ai",
    "agents",
    "orchestration",
    "voice",
    "web",
    "search",
    "brave",
    "serper",
    "duckduckgo",
    "fetch",
    "sitemap"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tuttiai/tutti",
    "directory": "voices/web"
  },
  "homepage": "https://tutti-ai.com"
}
