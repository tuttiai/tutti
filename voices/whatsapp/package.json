{
  "name": "@tuttiai/whatsapp",
  "version": "0.1.0",
  "description": "Tutti voice — send and receive WhatsApp messages via Meta's Cloud API; shared webhook server for @tuttiai/inbox",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "5.8.5",
    "zod": "3.25.76"
  },
  "peerDependencies": {
    "@tuttiai/core": ">=0.11.0",
    "@tuttiai/types": ">=0.9.0"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tuttiai/tutti",
    "directory": "voices/whatsapp"
  },
  "homepage": "https://tutti-ai.com",
  "keywords": ["tutti", "ai", "agents", "whatsapp", "meta", "cloud-api", "webhook", "voice"]
}
