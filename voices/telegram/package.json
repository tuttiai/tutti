{
  "name": "@tuttiai/telegram",
  "version": "0.1.0",
  "description": "Tutti voice — read, post and moderate Telegram messages from agents; shared bot client for @tuttiai/inbox",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "telegraf": "4.16.3",
    "zod": "3.25.76"
  },
  "peerDependencies": {
    "@tuttiai/core": ">=0.11.0",
    "@tuttiai/types": ">=0.9.0"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tuttiai/tutti",
    "directory": "voices/telegram"
  },
  "homepage": "https://tutti-ai.com",
  "keywords": ["tutti", "ai", "agents", "telegram", "chatbot", "voice"]
}
